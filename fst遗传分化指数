cat(sprintf("  染色体数: %d\n", length(unique(vcf@fix[, 1]))))
cat(sprintf("  群体数: %d\n", length(pop_names)))
cat(sprintf("  群体组成: %s\n",
            paste(sprintf("%s(n=%d)", pop_names,
                          sapply(pop_names, function(p) sum(pop_df$pop == p))),
                  collapse = ", ")))
cat("\n")

cat("--- 数据质量 ---\n")
