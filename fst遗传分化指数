cat("  eda_results/02_maf_distribution.pdf    - MAF 分布\n")
cat("  eda_results/03_genotype_heatmap.pdf    - 基因型热图\n")
cat("  eda_results/04_pca.pdf                - PCA 图\n")
cat("  eda_results/05_af_comparison_*.pdf     - 等位基因频率对比\n")
