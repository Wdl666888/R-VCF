cat(sprintf("  个体平均缺失率: %.4f\n", mean(miss_by_ind)))
cat(sprintf("  MAF < 0.05 的 SNP: %d (%.1f%%)\n",
            sum(af < 0.05, na.rm = TRUE),
            sum(af < 0.05, na.rm = TRUE) / length(na.omit(af)) * 100))
cat("\n")

cat("--- 群体结构 (PCA) ---\n")
cat(sprintf("  PC1 方差解释: %.1f%%\n", var_ratio[1]))
cat(sprintf("  PC2 方差解释: %.1f%%\n", var_ratio[2]))
cat(sprintf("  PC3 方差解释: %.1f%%\n", var_ratio[3]))
cat("\n")

cat("--- 杂合度 ---\n")
for (pop in pop_names) {
  sub <- het_df[het_df$Population == pop, ]
  cat(sprintf("  %s: 平均 Ho=%.4f, 平均 He=%.4f\n",
